# ── PostgreSQL (Docker Compose) ───────────────────────────────────────────
POSTGRES_USER=nutrisipe
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=nutrisipe
POSTGRES_PORT=5432

# ── Backend ───────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# SQLite (dev) or PostgreSQL connection string (prod)
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://nutrisipe:your_password@localhost:5432/nutrisipe"

JWT_SECRET=replace_with_long_random_secret

# Frontend origin for CORS
CORS_ORIGIN=http://localhost:5173

# ── Cloudinary (image uploads + responsive srcset) ────────────────────────
# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Optional: single-URL alternative (replaces the three vars above)
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ── Frontend (Vite) ───────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001/api
