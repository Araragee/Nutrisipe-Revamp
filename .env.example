# PostgreSQL Configuration
POSTGRES_USER=nutrisipe
POSTGRES_PASSWORD=password123
POSTGRES_DB=nutrisipe_prod

# JSON Web Token Secret (Change in production, 32+ characters minimum)
JWT_SECRET=your-production-super-secret-jwt-key-32-chars-min

# Cross-Origin Resource Sharing (CORS) Origin Configuration
CORS_ORIGIN=*

# Google OAuth Client ID for User Authentication
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Public URL of the Server (Optional, for absolute URLs in OG tags)
PUBLIC_URL=http://localhost
