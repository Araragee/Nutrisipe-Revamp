# Database
DATABASE_URL="postgresql://nutrisipe:nutrisipe@localhost:5432/nutrisipe?schema=public"

# JWT
# Dev-only value. For production, generate a strong secret (min 32 chars):
#   openssl rand -base64 48
# The server refuses to start in production with a placeholder/short secret.
JWT_SECRET="dev-only-secret-do-not-use-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV="development"

# CORS
CORS_ORIGIN="http://localhost:5173"
