{
    "name": "nutrisipe-backend",
    "version": "1.0.0",
    "description": "Backend API for Nutrisipe - Pinterest-style recipe sharing platform",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "npm install --include=dev && tsc",
        "start": "node dist/index.js",
        "test": "jest",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:seed": "tsx prisma/seed.ts",
        "prisma:seed-ingredients": "tsx prisma/seed-ingredients.ts",
        "prisma:seed-engagement": "tsx prisma/seed-engagement.ts",
        "prisma:studio": "prisma studio",
        "seed:all": "npm run prisma:seed && npm run prisma:seed-ingredients && npm run prisma:seed-engagement"
    },
    "keywords": [
        "recipe",
        "social",
        "api"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@prisma/client": "^5.22.0",
        "@types/socket.io": "^3.0.1",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^8.2.1",
        "jsonwebtoken": "^9.0.2",
        "multer": "^2.0.2",
        "prisma": "^5.22.0",
        "socket.io": "^4.8.3",
        "uuid": "^14.0.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/express-rate-limit": "^5.1.3",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/node": "^20.10.6",
        "@types/uuid": "^9.0.7",
        "jest": "^30.2.0",
        "nodemon": "^3.0.2",
        "prisma": "^5.22.0",
        "ts-jest": "^29.4.11",
        "ts-node": "^10.9.2",
        "tsx": "^4.7.0",
        "typescript": "^5.3.3"
    },
    "prisma": {
        "seed": "tsx prisma/seed.ts"
    }
}
